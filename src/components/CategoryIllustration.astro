{category === 'Race Engineering Use Cases' && (
<svg viewBox="0 0 800 260" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Race Engineering illustration">
  <defs>
    <linearGradient id="bg-race" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#7f1d1d"/>
      <stop offset="100%" style="stop-color:#0f172a"/>
    </linearGradient>
  </defs>
  <rect width="800" height="260" fill="url(#bg-race)"/>
  <!-- telemetry grid -->
  <g stroke="rgba(255,255,255,0.06)" stroke-width="1">
    {[40,80,120,160,200].map(y => (
      <line x1="50" y1={y} x2="550" y2={y}/>
    ))}
    {[50,150,250,350,450,550].map(x => (
      <line x1={x} y1="30" x2={x} y2="220"/>
    ))}
  </g>
  <!-- speed trace -->
  <polyline
    points="50,200 90,170 130,120 160,90 200,80 240,95 270,130 300,115 340,80 380,70 420,85 460,140 490,165 530,150 550,145"
    fill="none" stroke="#ef4444" stroke-width="2.5" stroke-linejoin="round"/>
  <!-- throttle trace -->
  <polyline
    points="50,210 90,180 130,140 160,110 200,100 240,115 270,150 300,135 340,100 380,90 420,105 460,165 490,185 530,170 550,165"
    fill="none" stroke="#22c55e" stroke-width="1.5" stroke-linejoin="round" stroke-dasharray="4 2"/>
  <!-- brake trace -->
  <polyline
    points="50,215 90,214 130,210 160,195 200,215 240,215 270,200 300,215 340,212 380,215 420,215 460,200 490,210 530,215 550,215"
    fill="none" stroke="#3b82f6" stroke-width="1.5" stroke-linejoin="round"/>
  <!-- labels -->
  <rect x="56" y="34" width="8" height="8" rx="1" fill="#ef4444"/>
  <text x="70" y="43" font-family="monospace" font-size="10" fill="rgba(255,255,255,0.6)">Speed</text>
  <rect x="116" y="34" width="8" height="8" rx="1" fill="#22c55e"/>
  <text x="130" y="43" font-family="monospace" font-size="10" fill="rgba(255,255,255,0.6)">Throttle</text>
  <rect x="196" y="34" width="8" height="8" rx="1" fill="#3b82f6"/>
  <text x="210" y="43" font-family="monospace" font-size="10" fill="rgba(255,255,255,0.6)">Brake</text>
  <!-- Y axis labels -->
  <text x="36" y="44" font-family="monospace" font-size="9" fill="rgba(255,255,255,0.3)" text-anchor="end">300</text>
