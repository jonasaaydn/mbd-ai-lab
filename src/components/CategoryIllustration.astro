---
interface Props {
  category: string;
}
const { category } = Astro.props;
---

{category === 'AI Coding' && (
<svg viewBox="0 0 800 260" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="AI Coding illustration">
  <defs>
    <linearGradient id="bg-aic" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#1e3a8a"/>
      <stop offset="100%" style="stop-color:#312e81"/>
    </linearGradient>
  </defs>
  <rect width="800" height="260" fill="url(#bg-aic)"/>
  <!-- dot grid -->
  <pattern id="dots-aic" x="0" y="0" width="24" height="24" patternUnits="userSpaceOnUse">
    <circle cx="2" cy="2" r="1" fill="rgba(255,255,255,0.07)"/>
  </pattern>
  <rect width="800" height="260" fill="url(#dots-aic)"/>
  <!-- editor window -->
  <rect x="60" y="30" width="460" height="200" rx="10" fill="rgba(0,0,0,0.45)" stroke="rgba(255,255,255,0.1)" stroke-width="1"/>
  <!-- title bar -->
  <rect x="60" y="30" width="460" height="36" rx="10" fill="rgba(0,0,0,0.3)"/>
  <rect x="60" y="52" width="460" height="14" fill="rgba(0,0,0,0.3)"/>
  <circle cx="87" cy="48" r="6" fill="#ef4444"/>
  <circle cx="109" cy="48" r="6" fill="#f59e0b"/>
  <circle cx="131" cy="48" r="6" fill="#22c55e"/>
  <text x="200" y="53" font-family="monospace" font-size="11" fill="rgba(255,255,255,0.4)">main.py</text>
  <!-- code lines -->
  <text x="82" y="92" font-family="monospace" font-size="12" fill="#94a3b8">01</text>
  <text x="110" y="92" font-family="monospace" font-size="12" fill="#c084fc">import</text>
  <text x="167" y="92" font-family="monospace" font-size="12" fill="#e2e8f0"> anthropic</text>
  <text x="82" y="114" font-family="monospace" font-size="12" fill="#94a3b8">02</text>
  <text x="82" y="136" font-family="monospace" font-size="12" fill="#94a3b8">03</text>
  <text x="110" y="136" font-family="monospace" font-size="12" fill="#60a5fa">client</text>
  <text x="165" y="136" font-family="monospace" font-size="12" fill="#e2e8f0"> = anthropic.</text>
  <text x="296" y="136" font-family="monospace" font-size="12" fill="#34d399">Anthropic</text>
  <text x="371" y="136" font-family="monospace" font-size="12" fill="#e2e8f0">()</text>
  <text x="82" y="158" font-family="monospace" font-size="12" fill="#94a3b8">04</text>
  <text x="110" y="158" font-family="monospace" font-size="12" fill="#60a5fa">message</text>
  <text x="183" y="158" font-family="monospace" font-size="12" fill="#e2e8f0"> = client.</text>
  <text x="260" y="158" font-family="monospace" font-size="12" fill="#34d399">messages</text>
  <text x="330" y="158" font-family="monospace" font-size="12" fill="#e2e8f0">.</text>
  <text x="340" y="158" font-family="monospace" font-size="12" fill="#fbbf24">create</text>
  <text x="390" y="158" font-family="monospace" font-size="12" fill="#e2e8f0">(</text>
  <text x="82" y="180" font-family="monospace" font-size="12" fill="#94a3b8">05</text>
  <text x="110" y="180" font-family="monospace" font-size="12" fill="#60a5fa">    model</text>
  <text x="175" y="180" font-family="monospace" font-size="12" fill="#e2e8f0">=</text>
  <text x="185" y="180" font-family="monospace" font-size="12" fill="#f9a8d4">"claude-sonnet-4-6"</text>
  <!-- cursor blink -->
  <rect x="370" y="170" width="2" height="14" fill="#60a5fa" opacity="0.9"/>
  <!-- AI badge -->
  <rect x="560" y="50" width="170" height="160" rx="12" fill="rgba(99,102,241,0.15)" stroke="rgba(99,102,241,0.4)" stroke-width="1.5"/>
  <text x="645" y="90" font-family="sans-serif" font-size="11" fill="rgba(255,255,255,0.5)" text-anchor="middle">AI OUTPUT</text>
  <line x1="575" y1="100" x2="715" y2="100" stroke="rgba(255,255,255,0.1)" stroke-width="1"/>
  <text x="645" y="122" font-family="sans-serif" font-size="12" fill="rgba(255,255,255,0.75)" text-anchor="middle">解析完了</text>
  <text x="645" y="142" font-family="sans-serif" font-size="11" fill="rgba(255,255,255,0.5)" text-anchor="middle">処理時間: 1.2s</text>
  <text x="645" y="162" font-family="sans-serif" font-size="11" fill="#34d399" text-anchor="middle">✓ 正常終了</text>
  <!-- connecting arrow -->
  <line x1="522" y1="158" x2="556" y2="158" stroke="rgba(99,102,241,0.6)" stroke-width="1.5" stroke-dasharray="4 3"/>
  <polygon points="554,154 562,158 554,162" fill="rgba(99,102,241,0.6)"/>
  <!-- label -->
  <text x="400" y="248" font-family="sans-serif" font-size="13" fill="rgba(255,255,255,0.3)" text-anchor="middle" letter-spacing="3">AI CODING</text>
</svg>
)}

{category === 'MBD / Simulink' && (
<svg viewBox="0 0 800 260" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="MBD Simulink illustration">
  <defs>
    <linearGradient id="bg-mbd" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#4c1d95"/>
      <stop offset="100%" style="stop-color:#1e3a8a"/>
    </linearGradient>
  </defs>
  <rect width="800" height="260" fill="url(#bg-mbd)"/>
  <pattern id="grid-mbd" x="0" y="0" width="32" height="32" patternUnits="userSpaceOnUse">
    <path d="M 32 0 L 0 0 0 32" fill="none" stroke="rgba(255,255,255,0.05)" stroke-width="1"/>
  </pattern>
  <rect width="800" height="260" fill="url(#grid-mbd)"/>
  <!-- signal source -->
  <rect x="50" y="100" width="120" height="60" rx="8" fill="rgba(255,255,255,0.1)" stroke="rgba(167,139,250,0.6)" stroke-width="1.5"/>
  <text x="110" y="127" font-family="sans-serif" font-size="11" fill="rgba(255,255,255,0.6)" text-anchor="middle">Signal</text>
  <text x="110" y="145" font-family="sans-serif" font-size="13" fill="white" text-anchor="middle" font-weight="600">Source</text>
  <!-- arrow 1 -->
  <line x1="170" y1="130" x2="218" y2="130" stroke="rgba(167,139,250,0.7)" stroke-width="2"/>
  <polygon points="214,125 224,130 214,135" fill="rgba(167,139,250,0.7)"/>
  <text x="194" y="120" font-family="monospace" font-size="10" fill="rgba(255,255,255,0.4)" text-anchor="middle">u(t)</text>
  <!-- model block -->
  <rect x="220" y="75" width="160" height="110" rx="8" fill="rgba(99,102,241,0.25)" stroke="rgba(99,102,241,0.7)" stroke-width="2"/>
  <text x="300" y="120" font-family="sans-serif" font-size="12" fill="rgba(255,255,255,0.7)" text-anchor="middle">Simulink</text>
  <text x="300" y="140" font-family="sans-serif" font-size="14" fill="white" text-anchor="middle" font-weight="700">モデル</text>
  <text x="300" y="162" font-family="sans-serif" font-size="10" fill="rgba(255,255,255,0.45)" text-anchor="middle">Plant + Controller</text>
  <!-- arrow 2 -->
  <line x1="380" y1="130" x2="428" y2="130" stroke="rgba(167,139,250,0.7)" stroke-width="2"/>
  <polygon points="424,125 434,130 424,135" fill="rgba(167,139,250,0.7)"/>
  <text x="404" y="120" font-family="monospace" font-size="10" fill="rgba(255,255,255,0.4)" text-anchor="middle">y(t)</text>
  <!-- output block -->
  <rect x="430" y="100" width="120" height="60" rx="8" fill="rgba(255,255,255,0.1)" stroke="rgba(167,139,250,0.6)" stroke-width="1.5"/>
  <text x="490" y="127" font-family="sans-serif" font-size="11" fill="rgba(255,255,255,0.6)" text-anchor="middle">Scope /</text>
  <text x="490" y="145" font-family="sans-serif" font-size="13" fill="white" text-anchor="middle" font-weight="600">Output</text>
  <!-- feedback arrow -->
  <path d="M 490 160 L 490 210 L 110 210 L 110 160" stroke="rgba(251,191,36,0.5)" stroke-width="1.5" fill="none" stroke-dasharray="5 4"/>
  <polygon points="106,164 110,154 114,164" fill="rgba(251,191,36,0.5)"/>
  <text x="300" y="227" font-family="sans-serif" font-size="10" fill="rgba(251,191,36,0.5)" text-anchor="middle">フィードバック</text>
  <!-- AI enhancement -->
  <rect x="610" y="80" width="150" height="100" rx="10" fill="rgba(99,102,241,0.2)" stroke="rgba(99,102,241,0.5)" stroke-width="1.5"/>
  <text x="685" y="115" font-family="sans-serif" font-size="11" fill="rgba(255,255,255,0.5)" text-anchor="middle">AI Copilot</text>
  <text x="685" y="138" font-family="sans-serif" font-size="12" fill="white" text-anchor="middle">自動生成</text>
  <text x="685" y="158" font-family="sans-serif" font-size="10" fill="rgba(167,139,250,0.7)" text-anchor="middle">ブロック線図</text>
  <line x1="550" y1="130" x2="608" y2="130" stroke="rgba(99,102,241,0.4)" stroke-width="1.5" stroke-dasharray="4 3"/>
  <polygon points="606,126 614,130 606,134" fill="rgba(99,102,241,0.4)"/>
  <text x="400" y="250" font-family="sans-serif" font-size="13" fill="rgba(255,255,255,0.3)" text-anchor="middle" letter-spacing="3">MBD / SIMULINK</text>
</svg>
)}

{category === 'CAE / Simulation AI' && (
<svg viewBox="0 0 800 260" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="CAE Simulation AI illustration">
  <defs>
    <linearGradient id="bg-cae" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#064e3b"/>
      <stop offset="100%" style="stop-color:#0c4a6e"/>
    </linearGradient>
    <linearGradient id="heat" x1="0%" y1="0%" x2="100%" y2="0%">
      <stop offset="0%" style="stop-color:#1d4ed8"/>
      <stop offset="30%" style="stop-color:#06b6d4"/>
      <stop offset="60%" style="stop-color:#22c55e"/>
      <stop offset="80%" style="stop-color:#f59e0b"/>
      <stop offset="100%" style="stop-color:#ef4444"/>
    </linearGradient>
  </defs>
  <rect width="800" height="260" fill="url(#bg-cae)"/>
  <!-- mesh grid -->
  <g stroke="rgba(255,255,255,0.08)" stroke-width="0.8">
    {Array.from({length: 18}).map((_, i) => (
      <line x1={40 + i * 26} y1="20" x2={40 + i * 26} y2="230"/>
    ))}
    {Array.from({length: 9}).map((_, i) => (
      <line x1="40" y1={20 + i * 26} x2="500" y2={20 + i * 26}/>
    ))}
  </g>
  <!-- airfoil shape with heat map -->
  <path d="M 80 130 C 120 80, 280 60, 420 130 C 280 185, 120 175, 80 130 Z" fill="rgba(6,182,212,0.25)" stroke="rgba(6,182,212,0.5)" stroke-width="1.5"/>
  <!-- pressure contours -->
  <path d="M 80 130 C 110 95, 260 75, 380 130" stroke="#22c55e" stroke-width="1.5" fill="none" opacity="0.6"/>
  <path d="M 80 130 C 110 108, 260 95, 360 130" stroke="#06b6d4" stroke-width="1.5" fill="none" opacity="0.6"/>
  <path d="M 80 130 C 115 152, 265 162, 400 130" stroke="#f59e0b" stroke-width="1.5" fill="none" opacity="0.6"/>
  <path d="M 80 130 C 115 165, 265 175, 420 130" stroke="#ef4444" stroke-width="1.5" fill="none" opacity="0.6"/>
  <!-- flow arrows -->
  <g stroke="rgba(255,255,255,0.35)" stroke-width="1.2" fill="none">
    <line x1="30" y1="90" x2="70" y2="90"/><polygon points="68,86 76,90 68,94" fill="rgba(255,255,255,0.35)" stroke="none"/>
    <line x1="30" y1="115" x2="70" y2="115"/><polygon points="68,111 76,115 68,119" fill="rgba(255,255,255,0.35)" stroke="none"/>
    <line x1="30" y1="140" x2="70" y2="140"/><polygon points="68,136 76,140 68,144" fill="rgba(255,255,255,0.35)" stroke="none"/>
    <line x1="30" y1="165" x2="70" y2="165"/><polygon points="68,161 76,165 68,169" fill="rgba(255,255,255,0.35)" stroke="none"/>
  </g>
  <!-- colorbar -->
  <rect x="470" y="40" width="16" height="180" fill="url(#heat)" rx="3"/>
  <text x="492" y="44" font-family="monospace" font-size="10" fill="rgba(255,255,255,0.6)">High</text>
  <text x="492" y="224" font-family="monospace" font-size="10" fill="rgba(255,255,255,0.6)">Low</text>
  <text x="492" y="134" font-family="monospace" font-size="10" fill="rgba(255,255,255,0.4)">P</text>
  <!-- AI panel -->
  <rect x="530" y="50" width="230" height="160" rx="10" fill="rgba(0,0,0,0.3)" stroke="rgba(6,182,212,0.4)" stroke-width="1.5"/>
  <text x="645" y="80" font-family="sans-serif" font-size="11" fill="rgba(255,255,255,0.5)" text-anchor="middle">Surrogate Model</text>
  <line x1="545" y1="90" x2="745" y2="90" stroke="rgba(255,255,255,0.1)" stroke-width="1"/>
  <text x="545" y="112" font-family="monospace" font-size="11" fill="rgba(6,182,212,0.8)">Cd = 0.312</text>
  <text x="545" y="130" font-family="monospace" font-size="11" fill="rgba(6,182,212,0.8)">Cl = -0.847</text>
  <text x="545" y="148" font-family="monospace" font-size="11" fill="rgba(34,197,94,0.8)">▲ 94% faster</text>
  <text x="545" y="168" font-family="monospace" font-size="11" fill="rgba(255,255,255,0.5)">vs CFD: 0.309</text>
  <text x="545" y="188" font-family="monospace" font-size="11" fill="rgba(255,255,255,0.5)">error: 0.97%</text>
  <text x="400" y="250" font-family="sans-serif" font-size="13" fill="rgba(255,255,255,0.3)" text-anchor="middle" letter-spacing="3">CAE / SIMULATION AI</text>
</svg>
)}

{category === 'Research AI' && (
<svg viewBox="0 0 800 260" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Research AI illustration">
  <defs>
    <linearGradient id="bg-res" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#78350f"/>
      <stop offset="100%" style="stop-color:#7c2d12"/>
    </linearGradient>
  </defs>
  <rect width="800" height="260" fill="url(#bg-res)"/>
  <pattern id="dots-res" x="0" y="0" width="20" height="20" patternUnits="userSpaceOnUse">
    <circle cx="2" cy="2" r="1" fill="rgba(255,255,255,0.05)"/>
  </pattern>
  <rect width="800" height="260" fill="url(#dots-res)"/>
  <!-- knowledge graph connections -->
  <g stroke="rgba(251,191,36,0.2)" stroke-width="1">
    <line x1="200" y1="130" x2="100" y2="70"/>
    <line x1="200" y1="130" x2="310" y2="65"/>
    <line x1="200" y1="130" x2="130" y2="195"/>
    <line x1="200" y1="130" x2="320" y2="190"/>
    <line x1="200" y1="130" x2="90" y2="150"/>
    <line x1="100" y1="70" x2="310" y2="65"/>
    <line x1="310" y1="65" x2="420" y2="90"/>
    <line x1="320" y1="190" x2="420" y2="160"/>
    <line x1="420" y1="90" x2="420" y2="160"/>
  </g>
  <!-- nodes -->
  <circle cx="200" cy="130" r="28" fill="rgba(251,191,36,0.25)" stroke="rgba(251,191,36,0.7)" stroke-width="2"/>
  <text x="200" y="127" font-family="sans-serif" font-size="10" fill="white" text-anchor="middle">PINN</text>
  <text x="200" y="140" font-family="sans-serif" font-size="10" fill="white" text-anchor="middle">論文</text>
  <circle cx="100" cy="70" r="18" fill="rgba(239,68,68,0.2)" stroke="rgba(239,68,68,0.5)" stroke-width="1.5"/>
  <text x="100" y="74" font-family="sans-serif" font-size="9" fill="white" text-anchor="middle">CFD</text>
  <circle cx="310" cy="65" r="18" fill="rgba(99,102,241,0.2)" stroke="rgba(99,102,241,0.5)" stroke-width="1.5"/>
  <text x="310" y="69" font-family="sans-serif" font-size="9" fill="white" text-anchor="middle">FEM</text>
  <circle cx="130" cy="195" r="16" fill="rgba(34,197,94,0.2)" stroke="rgba(34,197,94,0.5)" stroke-width="1.5"/>
  <text x="130" y="199" font-family="sans-serif" font-size="9" fill="white" text-anchor="middle">MBD</text>
  <circle cx="320" cy="190" r="16" fill="rgba(6,182,212,0.2)" stroke="rgba(6,182,212,0.5)" stroke-width="1.5"/>
  <text x="320" y="194" font-family="sans-serif" font-size="9" fill="white" text-anchor="middle">CAE</text>
  <circle cx="90" cy="150" r="14" fill="rgba(251,191,36,0.15)" stroke="rgba(251,191,36,0.4)" stroke-width="1.5"/>
  <text x="90" y="154" font-family="sans-serif" font-size="8" fill="white" text-anchor="middle">AI</text>
  <circle cx="420" cy="90" r="16" fill="rgba(167,139,250,0.2)" stroke="rgba(167,139,250,0.5)" stroke-width="1.5"/>
  <text x="420" y="94" font-family="sans-serif" font-size="9" fill="white" text-anchor="middle">LLM</text>
  <circle cx="420" cy="160" r="16" fill="rgba(251,113,133,0.2)" stroke="rgba(251,113,133,0.5)" stroke-width="1.5"/>
  <text x="420" y="164" font-family="sans-serif" font-size="9" fill="white" text-anchor="middle">Race</text>
