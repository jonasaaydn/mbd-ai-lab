  <text x="625" y="70" font-family="sans-serif" font-size="11" fill="rgba(255,255,255,0.5)" text-anchor="middle">AI Paper Summary</text>
  <line x1="505" y1="80" x2="745" y2="80" stroke="rgba(255,255,255,0.1)" stroke-width="1"/>
  <rect x="505" y="92" width="240" height="10" rx="3" fill="rgba(255,255,255,0.15)"/>
  <rect x="505" y="108" width="200" height="10" rx="3" fill="rgba(255,255,255,0.1)"/>
  <rect x="505" y="124" width="220" height="10" rx="3" fill="rgba(255,255,255,0.1)"/>
  <rect x="505" y="140" width="180" height="10" rx="3" fill="rgba(255,255,255,0.08)"/>
  <text x="505" y="175" font-family="sans-serif" font-size="11" fill="rgba(251,191,36,0.8)">MBD応用度: ★★★★☆</text>
  <text x="505" y="195" font-family="sans-serif" font-size="10" fill="rgba(255,255,255,0.4)">arXiv:2503.12847</text>
  <text x="400" y="250" font-family="sans-serif" font-size="13" fill="rgba(255,255,255,0.3)" text-anchor="middle" letter-spacing="3">RESEARCH AI</text>
