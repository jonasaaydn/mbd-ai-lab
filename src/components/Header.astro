---
const base = import.meta.env.BASE_URL;
const navLinks = [
  { href: `${base}blog`, label: '記事一覧' },
  { href: `${base}tools`, label: 'AIツール' },
  { href: `${base}categories/race-engineering-use-cases`, label: 'Race Engineering' },
];

const currentPath = Astro.url.pathname;
---

<header class="site-header">
  <div class="container header-inner">
    <a href={base} class="site-logo">
      <span class="logo-icon" aria-hidden="true">⚙</span>
      <span class="logo-text">
        <span class="logo-main">MBD×AI Lab</span>
        <span class="logo-sub">Race Engineering × AI Tools</span>
      </span>
    </a>

    <button class="nav-toggle" id="nav-toggle" aria-label="メニューを開く" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>

    <nav class="site-nav" id="site-nav" aria-label="メインナビゲーション">
      <ul class="nav-list">
        {navLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class:list={['nav-link', { active: currentPath.startsWith(link.href) }]}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--color-border);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 60px;
    gap: 1rem;
  }

  .site-logo {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    text-decoration: none;
    flex-shrink: 0;
  }

  .logo-icon {
    font-size: 1.4rem;
    color: var(--color-accent);
    line-height: 1;
  }

  .logo-text {
    display: flex;
    flex-direction: column;
    line-height: 1.2;
  }

  .logo-main {
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-navy);
    letter-spacing: -0.02em;
  }

  .logo-sub {
    font-size: 0.62rem;
    font-weight: 500;
    color: var(--color-text-muted);
    letter-spacing: 0.02em;
  }

  .site-nav {
    display: flex;
    align-items: center;
  }

  .nav-list {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .nav-link {
    display: block;
    padding: 0.4em 0.75em;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-text-muted);
    border-radius: var(--radius-md);
    transition: color 0.15s, background 0.15s;
    white-space: nowrap;
  }

  .nav-link:hover,
  .nav-link.active {
    color: var(--color-text);
    background: var(--color-bg-muted);
  }

  .nav-link.active {
    color: var(--color-accent);
    font-weight: 600;
  }

  /* Hamburger */
  .nav-toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 36px;
    height: 36px;
    background: none;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    cursor: pointer;
    padding: 0 8px;
  }

  .nav-toggle span {
    display: block;
    width: 100%;
    height: 2px;
    background: var(--color-text);
    border-radius: 2px;
    transition: transform 0.2s, opacity 0.2s;
  }

  @media (max-width: 640px) {
    .nav-toggle {
      display: flex;
    }

    .site-nav {
      display: none;
      position: absolute;
      top: 60px;
      left: 0;
      right: 0;
      background: var(--color-bg);
      border-bottom: 1px solid var(--color-border);
      padding: 1rem 1.25rem;
    }

    .site-nav.open {
      display: flex;
    }

    .nav-list {
      flex-direction: column;
      align-items: stretch;
      width: 100%;
    }

    .nav-link {
      padding: 0.65em 0.75em;
      font-size: 0.95rem;
    }
  }
</style>

<script>
  const toggle = document.getElementById('nav-toggle');
  const nav = document.getElementById('site-nav');

  toggle?.addEventListener('click', () => {
    const isOpen = nav?.classList.toggle('open');
    toggle.setAttribute('aria-expanded', String(isOpen));
    toggle.setAttribute('aria-label', isOpen ? 'メニューを閉じる' : 'メニューを開く');
  });
</script>
