---
import { categoryToSlug, CATEGORY_COLORS } from '../utils/categories';

const base = import.meta.env.BASE_URL;

interface Props {
  slug: string;
  title: string;
  date: Date;
  category: string;
  tags: string[];
  tool?: string;
  importance: 'high' | 'medium' | 'low';
  summary: string;
}

const { slug, title, date, category, tags, tool, importance, summary } = Astro.props;

const colors = CATEGORY_COLORS[category] ?? { from: '#0f172a', to: '#1e293b', label: category };

const formattedDate = date.toLocaleDateString('ja-JP', {
  year: 'numeric',
  month: '2-digit',
  day: '2-digit',
});

const importanceLabel = { high: '重要', medium: '注目', low: '参考' }[importance];

// カテゴリ別 SVG アイコン（24×24 viewBox、currentColor で色付け）
const ICONS: Record<string, string> = {
  'AI Coding': `
    <rect x="2" y="3" width="20" height="16" rx="2.5" stroke="currentColor" stroke-width="1.5" fill="none"/>
    <polyline points="8,10 5,13 8,16" stroke="currentColor" stroke-width="1.6" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
    <polyline points="16,10 19,13 16,16" stroke="currentColor" stroke-width="1.6" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
    <line x1="13.5" y1="8" x2="10.5" y2="18" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
  `,
  'MBD / Simulink': `
    <rect x="1" y="9" width="6" height="6" rx="1.5" stroke="currentColor" stroke-width="1.5" fill="none"/>
    <rect x="9" y="9" width="6" height="6" rx="1.5" stroke="currentColor" stroke-width="1.5" fill="none"/>
    <rect x="17" y="9" width="6" height="6" rx="1.5" stroke="currentColor" stroke-width="1.5" fill="none"/>
    <line x1="7" y1="12" x2="9" y2="12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
    <polyline points="7,12 8,12" stroke="currentColor" stroke-width="1.5"/>
    <line x1="15" y1="12" x2="17" y2="12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
    <line x1="4" y1="9" x2="4" y2="5" stroke="currentColor" stroke-width="1" stroke-dasharray="2 2" opacity="0.55"/>
    <line x1="12" y1="9" x2="12" y2="5" stroke="currentColor" stroke-width="1" stroke-dasharray="2 2" opacity="0.55"/>
    <line x1="20" y1="9" x2="20" y2="5" stroke="currentColor" stroke-width="1" stroke-dasharray="2 2" opacity="0.55"/>
  `,
  'CAE / Simulation AI': `
    <path d="M2 14 C5 7, 8 21, 11 14 C14 7, 17 21, 20 14" stroke="currentColor" stroke-width="1.7" fill="none" stroke-linecap="round"/>
    <path d="M2 10 C5 3, 8 17, 11 10 C14 3, 17 17, 20 10" stroke="currentColor" stroke-width="1.2" fill="none" stroke-linecap="round" opacity="0.4"/>
    <path d="M2 18 C5 11, 8 25, 11 18 C14 11, 17 25, 20 18" stroke="currentColor" stroke-width="1.2" fill="none" stroke-linecap="round" opacity="0.4"/>
  `,
  'Research AI': `
    <circle cx="10.5" cy="10.5" r="6.5" stroke="currentColor" stroke-width="1.5" fill="none"/>
    <line x1="15.5" y1="15.5" x2="21" y2="21" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
    <circle cx="9" cy="9.5" r="1.1" fill="currentColor"/>
    <circle cx="12" cy="9.5" r="1.1" fill="currentColor"/>
    <circle cx="10.5" cy="12.5" r="1.1" fill="currentColor"/>
    <line x1="9" y1="9.5" x2="10.5" y2="12.5" stroke="currentColor" stroke-width="0.9" opacity="0.6"/>
    <line x1="12" y1="9.5" x2="10.5" y2="12.5" stroke="currentColor" stroke-width="0.9" opacity="0.6"/>
  `,
  'Race Engineering Use Cases': `
    <path d="M5 19 A8 8 0 0 1 19 19" stroke="currentColor" stroke-width="1.6" fill="none" stroke-linecap="round"/>
    <path d="M12 19 L8.5 11.5" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"/>
    <circle cx="12" cy="19" r="2.2" fill="currentColor"/>
    <line x1="5.5" y1="15.5" x2="3.5" y2="15.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
    <line x1="7.5" y1="11.5" x2="6.5" y2="10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
    <line x1="12" y1="10" x2="12" y2="8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
    <line x1="16.5" y1="11.5" x2="17.5" y2="10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
    <line x1="18.5" y1="15.5" x2="20.5" y2="15.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
  `,
  'Weekly AI Update': `
    <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.5" fill="none"/>
    <line x1="12" y1="7" x2="12" y2="12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
    <line x1="12" y1="12" x2="16.5" y2="14.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
    <path d="M18.5 5.5 L17 8.5 L20.5 8.5 Z" fill="currentColor" opacity="0.8"/>
    <path d="M19.5 4 A9.5 9.5 0 0 1 21 12" stroke="currentColor" stroke-width="1.3" fill="none" stroke-linecap="round"/>
  `,
  'Tool Comparison': `
    <line x1="12" y1="4" x2="12" y2="20" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
    <line x1="5" y1="7.5" x2="19" y2="7.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
    <path d="M3.5 13.5 L5 7.5 L6.5 13.5 Q5 16 3.5 13.5Z" stroke="currentColor" stroke-width="1.2" fill="none" stroke-linejoin="round"/>
    <path d="M17.5 13.5 L19 7.5 L20.5 13.5 Q19 16 17.5 13.5Z" stroke="currentColor" stroke-width="1.2" fill="none" stroke-linejoin="round"/>
    <line x1="3" y1="19" x2="9" y2="19" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" opacity="0.55"/>
    <line x1="15" y1="19" x2="21" y2="19" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" opacity="0.55"/>
  `,
};

const iconSvg = ICONS[category] ?? ICONS['Tool Comparison'];
---

<article class="article-card">
  <a href={`${base}blog/${slug}`} class="card-link" aria-label={title}>

    <!-- Thumbnail -->
    <div
      class="card-thumb"
      style={`background: linear-gradient(135deg, ${colors.from} 0%, ${colors.to} 100%)`}
    >
      <!-- ドットグリッド背景 -->
      <div class="thumb-dots" aria-hidden="true"></div>
      <!-- 斜めストライプ -->
      <div class="thumb-stripe" aria-hidden="true"></div>

      <!-- カテゴリアイコン -->
      <div class="thumb-icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" width="54" height="54" fill="none" set:html={iconSvg} />
      </div>

      <!-- ツール名バッジ -->
      {tool && <span class="thumb-tool">{tool}</span>}

      <!-- カテゴリラベル（下部） -->
      <div class="thumb-footer" aria-hidden="true">
        <span class="thumb-label">{colors.label}</span>
        <span class={`thumb-imp thumb-imp-${importance}`}></span>
      </div>
    </div>

    <div class="card-meta">
      <a href={`${base}categories/${categoryToSlug(category)}`} class="category-badge" onclick="event.stopPropagation()">
        {category}
      </a>
      <span class={`badge badge-importance-${importance}`}>
        <span class={`importance-dot importance-dot-${importance}`}></span>
        {importanceLabel}
      </span>
    </div>

    <h2 class="card-title">{title}</h2>
    <p class="card-summary">{summary}</p>

    <div class="card-footer">
      <div class="card-tags">
        {tags.slice(0, 3).map((tag) => (
          <span class="tag">{tag}</span>
        ))}
        {tool && <span class="tag tag-tool">{tool}</span>}
      </div>
      <time class="card-date" datetime={date.toISOString()}>{formattedDate}</time>
    </div>
  </a>
</article>

<style>
  /* ── Thumbnail ── */
  .card-thumb {
    position: relative;
    height: 150px;
    overflow: hidden;
    flex-shrink: 0;
  }

  .thumb-dots {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle, rgba(255, 255, 255, 0.1) 1px, transparent 1px);
    background-size: 18px 18px;
    background-position: 9px 9px;
  }

  .thumb-stripe {
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      -45deg,
      transparent,
      transparent 18px,
      rgba(255, 255, 255, 0.03) 18px,
      rgba(255, 255, 255, 0.03) 36px
    );
  }

  .thumb-icon {
    position: absolute;
    left: 50%;
    top: 46%;
    transform: translate(-50%, -50%);
    color: rgba(255, 255, 255, 0.22);
    pointer-events: none;
    transition: color 0.2s;
  }

  .article-card:hover .thumb-icon {
    color: rgba(255, 255, 255, 0.35);
  }

  .thumb-tool {
    position: absolute;
    top: 10px;
    right: 12px;
    font-size: 0.68rem;
    font-weight: 700;
    color: rgba(255, 255, 255, 0.92);
    background: rgba(255, 255, 255, 0.14);
    border: 1px solid rgba(255, 255, 255, 0.22);
    border-radius: 4px;
    padding: 0.2em 0.65em;
    font-family: var(--font-mono);
    max-width: 140px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    backdrop-filter: blur(4px);
  }

  .thumb-footer {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 0 14px 10px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: linear-gradient(to top, rgba(0,0,0,0.3) 0%, transparent 100%);
  }

  .thumb-label {
    font-size: 0.62rem;
    font-weight: 800;
    letter-spacing: 0.16em;
    color: rgba(255, 255, 255, 0.5);
    font-family: var(--font-mono);
    text-transform: uppercase;
  }

  /* 重要度インジケータ（右下の小ドット列） */
  .thumb-imp {
    display: flex;
    gap: 3px;
  }
  .thumb-imp::before,
  .thumb-imp::after {
    content: '';
    display: block;
    width: 5px;
    height: 5px;
    border-radius: 50%;
  }
  .thumb-imp-high::before  { background: rgba(250,204,21,0.9); }
  .thumb-imp-high::after   { background: rgba(250,204,21,0.9); }
  .thumb-imp-medium::before { background: rgba(148,163,184,0.7); }
  .thumb-imp-medium::after  { background: rgba(148,163,184,0.35); }
  .thumb-imp-low::before   { background: rgba(148,163,184,0.35); }
  .thumb-imp-low::after    { background: rgba(148,163,184,0.15); }

  /* ── Card ── */
  .article-card {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    transition: box-shadow 0.15s ease, transform 0.15s ease;
    overflow: hidden;
  }

  .article-card:hover {
    box-shadow: var(--shadow-lg);
    transform: translateY(-2px);
  }

  .card-link {
    display: flex;
    flex-direction: column;
    height: 100%;
    padding: 1.35rem 1.5rem 1.25rem;
    text-decoration: none;
    color: inherit;
  }

  .card-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
    flex-wrap: wrap;
  }

  .card-title {
    font-size: 1rem;
    font-weight: 700;
    line-height: 1.45;
    color: var(--color-navy);
    margin-bottom: 0.6rem;
    flex-grow: 1;
    transition: color 0.15s;
  }

  .article-card:hover .card-title {
    color: var(--color-accent);
  }

  .card-summary {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    line-height: 1.6;
    margin: 0 0 1rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-footer {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 0.5rem;
    margin-top: auto;
  }

  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
  }

  .tag-tool {
    background: #f0fdf4;
    color: #15803d;
    border-color: #bbf7d0;
    font-weight: 600;
  }

  .card-date {
    font-size: 0.78rem;
    color: var(--color-text-subtle);
    white-space: nowrap;
    font-family: var(--font-mono);
    flex-shrink: 0;
  }
</style>
