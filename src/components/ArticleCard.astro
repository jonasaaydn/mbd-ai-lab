---
import { categoryToSlug } from '../utils/categories';

const base = import.meta.env.BASE_URL;

interface Props {
  slug: string;
  title: string;
  date: Date;
  category: string;
  tags: string[];
  tool?: string;
  importance: 'high' | 'medium' | 'low';
  summary: string;
}

const { slug, title, date, category, tags, tool, importance, summary } = Astro.props;

const formattedDate = date.toLocaleDateString('ja-JP', {
  year: 'numeric',
  month: '2-digit',
  day: '2-digit',
});

const importanceLabel = { high: '重要', medium: '注目', low: '参考' }[importance];
---

<article class="article-card">
  <a href={`${base}blog/${slug}`} class="card-link" aria-label={title}>
    <div class="card-meta">
      <a href={`${base}categories/${categoryToSlug(category)}`} class="category-badge" onclick="event.stopPropagation()">
        {category}
      </a>
      <span class={`badge badge-importance-${importance}`}>
        <span class={`importance-dot importance-dot-${importance}`}></span>
        {importanceLabel}
      </span>
    </div>

    <h2 class="card-title">{title}</h2>
    <p class="card-summary">{summary}</p>

    <div class="card-footer">
      <div class="card-tags">
        {tags.slice(0, 3).map((tag) => (
          <span class="tag">{tag}</span>
        ))}
        {tool && <span class="tag tag-tool">{tool}</span>}
      </div>
      <time class="card-date" datetime={date.toISOString()}>{formattedDate}</time>
    </div>
  </a>
</article>

<style>
  .article-card {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    transition: box-shadow 0.15s ease, transform 0.15s ease;
    overflow: hidden;
  }

  .article-card:hover {
    box-shadow: var(--shadow-lg);
    transform: translateY(-2px);
  }

  .card-link {
    display: flex;
    flex-direction: column;
    height: 100%;
    padding: 1.35rem 1.5rem 1.25rem;
    text-decoration: none;
    color: inherit;
  }

  .card-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
    flex-wrap: wrap;
  }

  .card-title {
    font-size: 1rem;
    font-weight: 700;
    line-height: 1.45;
    color: var(--color-navy);
    margin-bottom: 0.6rem;
    flex-grow: 1;
    transition: color 0.15s;
  }

  .article-card:hover .card-title {
    color: var(--color-accent);
  }

  .card-summary {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    line-height: 1.6;
    margin: 0 0 1rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-footer {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 0.5rem;
    margin-top: auto;
  }

  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
  }

  .tag-tool {
    background: #f0fdf4;
    color: #15803d;
    border-color: #bbf7d0;
    font-weight: 600;
  }

  .card-date {
    font-size: 0.78rem;
    color: var(--color-text-subtle);
    white-space: nowrap;
    font-family: var(--font-mono);
    flex-shrink: 0;
  }
</style>
