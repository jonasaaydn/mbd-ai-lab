---
import type { Tool } from '../data/tools';

interface Props {
  tool: Tool;
}

const { tool } = Astro.props;

const relevanceLabel = { high: 'MBD高関連', medium: '関連あり', low: '参考' }[tool.mbd_relevance];
const relevanceClass = `relevance-${tool.mbd_relevance}`;
---

<div class="tool-card">
  <div class="tool-header">
    <div class="tool-title-row">
      <h3 class="tool-name">{tool.name}</h3>
      <span class={`relevance-badge ${relevanceClass}`}>{relevanceLabel}</span>
    </div>
    <div class="tool-meta">
      <span class="tool-developer">{tool.developer}</span>
      <span class="tool-category">{tool.category}</span>
    </div>
  </div>

  <p class="tool-desc">{tool.description}</p>

  <div class="tool-use-cases">
    <h4 class="use-cases-title">活用場面</h4>
    <ul>
      {tool.use_cases.map((uc) => <li>{uc}</li>)}
    </ul>
  </div>

  <div class="tool-footer">
    <div class="tool-tags">
      {tool.tags.map((tag) => <span class="tag">{tag}</span>)}
    </div>
    <a
      href={tool.official_url}
      target="_blank"
      rel="noopener noreferrer"
      class="tool-link btn btn-outline"
    >
      公式サイト ↗
    </a>
  </div>
</div>

<style>
  .tool-card {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 1.4rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
    transition: box-shadow 0.15s, transform 0.15s;
  }

  .tool-card:hover {
    box-shadow: var(--shadow-lg);
    transform: translateY(-2px);
  }

  .tool-header {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .tool-title-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .tool-name {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--color-navy);
    margin: 0;
  }

  .tool-meta {
    display: flex;
    gap: 0.5rem;
    align-items: center;
    flex-wrap: wrap;
  }

  .tool-developer {
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--color-text-muted);
  }

  .tool-category {
    font-size: 0.72rem;
    background: var(--color-bg-muted);
    color: var(--color-text-muted);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    padding: 0.1em 0.5em;
  }

  .relevance-badge {
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    padding: 0.2em 0.55em;
    border-radius: var(--radius-sm);
    white-space: nowrap;
  }

  .relevance-high {
    background: #fef2f2;
    color: var(--importance-high);
    border: 1px solid #fecaca;
  }

  .relevance-medium {
    background: #fffbeb;
    color: var(--importance-medium);
    border: 1px solid #fed7aa;
  }

  .relevance-low {
    background: var(--color-bg-muted);
    color: var(--color-text-muted);
    border: 1px solid var(--color-border);
  }

  .tool-desc {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    line-height: 1.65;
    margin: 0;
  }

  .use-cases-title {
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-subtle);
    margin-bottom: 0.4rem;
  }

  .tool-use-cases ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .tool-use-cases li {
    font-size: 0.82rem;
    color: var(--color-text);
    padding-left: 0.85rem;
    position: relative;
  }

  .tool-use-cases li::before {
    content: '›';
    position: absolute;
    left: 0;
    color: var(--color-accent);
    font-weight: 700;
  }

  .tool-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    margin-top: auto;
    flex-wrap: wrap;
  }

  .tool-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
  }

  .tool-link {
    font-size: 0.78rem;
    padding: 0.35em 0.85em;
    flex-shrink: 0;
  }
</style>
