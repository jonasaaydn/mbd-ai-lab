---
import { SITE } from '../site.config';

// 記事末尾の収益化 CTA。設定（site.config.ts）が空なら該当ブロックを出さない。
const noteUrl = SITE.noteUrl;
const amazonUrl = SITE.amazonStorefrontUrl;
const hasAny = Boolean(noteUrl) || Boolean(amazonUrl);
---

{hasAny && (
  <div class="article-cta" data-pagefind-ignore>
    {noteUrl && (
      <section class="cta-note">
        <p class="cta-eyebrow">MBD×AI Lab note</p>
        <h2 class="cta-title">もっと深く・実践的に</h2>
        <p class="cta-text">
          より踏み込んだ実装解説・限定記事・質問への回答は note で公開しています。
          このサイトの運営（毎日のAI動向リサーチ）を応援していただける方も歓迎です。
        </p>
        <a href={noteUrl} target="_blank" rel="noopener noreferrer" class="cta-btn cta-btn-note">
          note を見る →
        </a>
      </section>
    )}

    {amazonUrl && (
      <section class="cta-books">
        <h2 class="cta-title">この分野をさらに学ぶ — おすすめの技術書</h2>
        <p class="cta-text">
          MBD・制御・CAE・機械学習をしっかり体系立てて学びたい人向けに、
          実務で役立った書籍を厳選して紹介しています。
        </p>
        <a href={amazonUrl} target="_blank" rel="sponsored nofollow noopener" class="cta-btn cta-btn-books">
          おすすめ書籍リストを見る →
        </a>
        <p class="cta-disclosure">※ Amazon アソシエイト・プログラムによる広告（リンク）を含みます。</p>
      </section>
    )}
  </div>
)}

<style>
  .article-cta {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    margin: 2.5rem 0 0.5rem;
  }
  .cta-note,
  .cta-books {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 1.5rem 1.6rem;
  }
  .cta-note {
    background: linear-gradient(180deg, #f8fafc 0%, #f1f5f9 100%);
    border-color: #dbe3ec;
  }
  .cta-books {
    background: var(--color-bg-subtle, #f8fafc);
  }
  .cta-eyebrow {
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-accent);
    margin: 0 0 0.4rem;
  }
  .cta-title {
    font-size: 1.2rem;
    color: var(--color-navy);
    margin: 0 0 0.55rem;
    border: 0;
    padding: 0;
  }
  .cta-text {
    font-size: 0.92rem;
    line-height: 1.75;
    color: var(--color-text);
    margin: 0 0 1rem;
  }
  .cta-btn {
    display: inline-block;
    font-weight: 700;
    font-size: 0.9rem;
    padding: 0.6em 1.3em;
    border-radius: var(--radius-md);
    text-decoration: none;
    transition: transform 0.15s, box-shadow 0.15s, opacity 0.15s;
  }
  .cta-btn:hover {
    transform: translateY(-1px);
    box-shadow: var(--shadow-lg);
  }
  .cta-btn-note {
    background: var(--color-navy);
    color: #fff;
  }
  .cta-btn-books {
    background: #ff9900;
    color: #1a1a1a;
  }
  .cta-disclosure {
    font-size: 0.72rem;
    color: var(--color-text-muted);
    margin: 0.7rem 0 0;
  }
</style>
