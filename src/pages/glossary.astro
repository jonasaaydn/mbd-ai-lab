---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Content, getHeadings } from '../glossary-data.md';

const base = import.meta.env.BASE_URL;
const headings = (await getHeadings()).filter((h) => h.depth === 3);
---

<BaseLayout
  title="MBD×AI 用語集"
  description="サロゲートモデル・PINN・スリップ率・MBDなど、レース車両開発とAIの専門用語を学生にもわかる言葉で解説する用語集。"
  canonicalPath="/glossary/"
>
  <section class="glossary-hero">
    <div class="container">
      <div class="g-label">GLOSSARY — 用語集</div>
      <h1 class="g-title">MBD × AI 用語集</h1>
      <p class="g-desc">
        記事に出てくる専門用語を、学生フォーミュラ参加者にもわかる言葉で解説します。
        全 <strong>{headings.length}</strong> 語。記事を読んでいて分からない言葉が出たら、ここで調べてください。
      </p>
    </div>
  </section>

  <div class="container glossary-body">
    <nav class="term-index" aria-label="用語一覧">
      {headings.map((h) => (
        <a href={`#${h.slug}`} class="term-chip">{h.text.replace(/（.*$/, '')}</a>
      ))}
    </nav>

    <div class="prose glossary-content" data-pagefind-body>
      <Content />
    </div>

    <div class="glossary-foot">
      <p>探している用語が見つからない場合は、記事検索もお試しください。</p>
      <a href={`${base}search`} class="btn btn-outline">記事を検索する</a>
    </div>
  </div>
</BaseLayout>

<style>
  .glossary-hero {
    background: var(--color-navy);
    color: #fff;
    padding: 3rem 0 2.5rem;
  }
  .g-label {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    color: var(--color-accent);
    font-family: var(--font-mono);
    margin-bottom: 0.75rem;
  }
  .g-title {
    font-size: clamp(1.5rem, 4vw, 2.2rem);
    font-weight: 800;
    color: #fff;
    letter-spacing: -0.03em;
    margin-bottom: 0.85rem;
  }
  .g-desc {
    font-size: 1rem;
    color: #94a3b8;
    line-height: 1.8;
    max-width: 640px;
  }
  .g-desc strong { color: #fca5a5; }

  .glossary-body { padding: 2rem 1.25rem 4rem; }

  .term-index {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    padding-bottom: 1.75rem;
    margin-bottom: 1.75rem;
    border-bottom: 1px solid var(--color-border);
  }
  .term-chip {
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--color-text-muted);
    background: var(--color-bg-subtle);
    border: 1px solid var(--color-border);
    border-radius: 9999px;
    padding: 0.3em 0.8em;
    transition: all 0.15s;
  }
  .term-chip:hover {
    color: #fff;
    background: var(--color-accent);
    border-color: var(--color-accent);
  }

  .glossary-content {
    max-width: 760px;
  }
  .glossary-content :global(h3) {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--color-navy);
    margin: 1.75rem 0 0.5rem;
    padding-top: 1rem;
    padding-left: 0.85rem;
    border-top: 1px solid var(--color-border);
    position: relative;
    scroll-margin-top: 80px;
  }
  .glossary-content :global(h3)::before {
    content: '';
    position: absolute;
    left: 0;
    top: 1rem;
    height: 1.1em;
    width: 3px;
    background: var(--color-accent);
    border-radius: 2px;
  }
  .glossary-content :global(h3:first-child) {
    border-top: none;
    padding-top: 0;
    margin-top: 0;
  }
  .glossary-content :global(h3:first-child)::before { top: 0; }
  .glossary-content :global(p) {
    line-height: 1.85;
    color: var(--color-text);
    margin-bottom: 0.5rem;
  }

  .glossary-foot {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
    text-align: center;
    color: var(--color-text-muted);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }
</style>
