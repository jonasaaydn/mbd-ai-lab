---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL;
const allPosts = await getCollection('blog');
const articleCount = allPosts.length;

// このサイトの編集方針（記事が満たすべき「価値フロア」）
const principles = [
  {
    title: '一次ソースを明示する',
    body: '論文・公式ドキュメント・実機データなど、根拠となる出典を必ずリンクする。出典のない主張・数字は載せない。',
  },
  {
    title: '動くコードを載せる',
    body: '読者（特に学生）がそのまま再現できる、日本語コメントつきの実装コードを示す。',
  },
  {
    title: '独自の比較・数字で語る',
    body: 'Before / After を具体的な数値で示し、複数ツールを横断して中立に比較する。特定ベンダーに偏らない。',
  },
  {
    title: 'レース車両開発に結びつける',
    body: 'すべての記事を、学生フォーミュラ・レース車両開発の具体的な応用シナリオに落とし込む。',
  },
];
---

<BaseLayout
  title="このサイトについて"
  description="MBD×AI Lab は、レース車両開発の現場で働くMBDエンジニアが運営する、ツール中立・日本語・実装コード重視の AI 技術ブログです。編集方針と運営者情報を掲載しています。"
  canonicalPath="/about/"
>
  <article class="about container">
    <header class="about-head">
      <p class="about-eyebrow">About</p>
      <h1>このサイトについて</h1>
      <p class="about-lead">
        <strong>MBD×AI Lab</strong> は、レース車両開発・モデルベース開発（MBD）×
        AI の最新動向を、<strong>特定ツールに偏らず・日本語で・実装コードつき</strong>で横断的にまとめる技術ブログです。
        現在 {articleCount} 本の記事を公開しています。
      </p>
    </header>

    <section class="about-section">
      <h2>運営者</h2>
      <p>
        本サイトは、<strong>レース車両のMBD（モデルベース開発）に携わる現役エンジニアが個人で運営</strong>しています。
        Simulink・CAE・制御・走行データ解析を実務で扱う立場から、「現場と学生チームの双方にとって本当に役立つか」を基準に題材を選んでいます。
      </p>
    </section>

    <section class="about-section">
      <h2>なぜこのサイトが必要か（立ち位置）</h2>
      <p>
        MBD・CAE・レース工学 × AI の良質な情報は、その多くが
        <strong>英語</strong>か、あるいは<strong>特定ツールベンダーの製品紹介</strong>に偏っています。
        現場のエンジニアや学生フォーミュラチームが、複数のツールを<strong>中立に・横断して・日本語で</strong>比較しながら追える場所はほとんどありません。
        MBD×AI Lab は、その空白を埋めることを目的としています。
      </p>
    </section>

    <section class="about-section">
      <h2>編集方針 — 記事が満たすべき基準</h2>
      <p>
        本サイトの記事は AI を活用して日々更新していますが、公開するすべての記事が次の基準（価値フロア）を満たすことを方針としています。
      </p>
      <ul class="principles">
        {principles.map((p) => (
          <li class="principle">
            <span class="principle-title">{p.title}</span>
            <span class="principle-body">{p.body}</span>
          </li>
        ))}
      </ul>
      <p class="about-note">
        誤りや古い情報、リンク切れにお気づきの場合は、出典とあわせてご指摘いただけると助かります。継続的に品質を改善していきます。
      </p>
    </section>

    <section class="about-section">
      <h2>対象読者</h2>
      <ul class="audience">
        <li>レース車両・量産車の <strong>MBD / 制御エンジニア</strong></li>
        <li>サーキットでデータと向き合う <strong>レースエンジニア</strong></li>
        <li><strong>学生フォーミュラ（FSAE / Formula Student）</strong>に取り組む学生</li>
      </ul>
    </section>

    <div class="about-actions">
      <a href={`${base}blog`} class="btn btn-primary">記事を読む</a>
      <a href={`${base}guide/student-formula`} class="btn btn-outline">学生フォーミュラ ガイド</a>
    </div>
  </article>
</BaseLayout>

<style>
  .about {
    max-width: 760px;
    padding-top: 3rem;
    padding-bottom: 3rem;
  }
  .about-head {
    margin-bottom: 2.5rem;
  }
  .about-eyebrow {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-accent);
    margin: 0 0 0.5rem;
  }
  .about-head h1 {
    font-size: 2rem;
    margin: 0 0 1rem;
    color: var(--color-navy);
  }
  .about-lead {
    font-size: 1.05rem;
    line-height: 1.8;
    color: var(--color-text);
    margin: 0;
  }
  .about-section {
    margin-bottom: 2.25rem;
  }
  .about-section h2 {
    font-size: 1.25rem;
    color: var(--color-navy);
    border-left: 4px solid var(--color-accent);
    padding-left: 0.65rem;
    margin: 0 0 0.9rem;
  }
  .about-section p {
    line-height: 1.85;
    color: var(--color-text);
    margin: 0 0 0.75rem;
  }
  .principles {
    list-style: none;
    padding: 0;
    margin: 1rem 0 0;
    display: grid;
    gap: 0.75rem;
  }
  .principle {
    background: var(--color-bg-subtle, #f8fafc);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 0.9rem 1.1rem;
  }
  .principle-title {
    display: block;
    font-weight: 700;
    color: var(--color-navy);
    margin-bottom: 0.3rem;
  }
  .principle-body {
    display: block;
    font-size: 0.92rem;
    line-height: 1.7;
    color: var(--color-text-muted);
  }
  .about-note {
    font-size: 0.9rem;
    color: var(--color-text-muted);
  }
  .audience {
    line-height: 2;
    padding-left: 1.2rem;
    margin: 0;
  }
  .about-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 2.5rem;
  }
</style>
