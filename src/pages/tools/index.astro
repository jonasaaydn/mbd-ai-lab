---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolCard from '../../components/ToolCard.astro';
import { tools } from '../../data/tools';

const toolCategories = [...new Set(tools.map((t) => t.category))];
---

<BaseLayout
  title="AIツール一覧"
  description="MBD・Simulink・CAE・レース車両開発に活用できるAIツールの一覧と解説"
>
  <div class="container">
    <div class="page-header">
      <h1>AIツール一覧</h1>
      <p class="page-desc">
        MBD・Simulink・CAE・レース車両開発に活用できるAIツールをまとめています。<br />
        各ツールの特徴、活用場面、MBD 関連度を確認できます。
      </p>
    </div>

    <!-- Filter by relevance -->
    <div class="relevance-summary">
      <div class="relevance-item">
        <span class="rel-dot rel-high"></span>
        <span>MBD高関連</span>
        <strong>{tools.filter((t) => t.mbd_relevance === 'high').length} ツール</strong>
      </div>
      <div class="relevance-item">
        <span class="rel-dot rel-medium"></span>
        <span>関連あり</span>
        <strong>{tools.filter((t) => t.mbd_relevance === 'medium').length} ツール</strong>
      </div>
    </div>

    {toolCategories.map((cat) => {
      const catTools = tools.filter((t) => t.category === cat);
      return (
        <section class="tool-section">
          <div class="section-header">
            <h2>{cat}</h2>
            <span class="tool-count">{catTools.length} ツール</span>
          </div>
          <div class="grid-2">
            {catTools.map((tool) => <ToolCard tool={tool} />)}
          </div>
        </section>
      );
    })}

    <div class="cta-section">
      <p>各ツールの実践活用事例は記事でも紹介しています。</p>
      <a href="/blog" class="btn btn-primary">記事を読む</a>
    </div>
  </div>
</BaseLayout>

<style>
  .page-header {
    padding: 2.5rem 0 2rem;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 2rem;
  }

  .page-header h1 {
    margin-bottom: 0.75rem;
  }

  .page-desc {
    font-size: 0.95rem;
    color: var(--color-text-muted);
    line-height: 1.7;
    margin: 0;
    max-width: 600px;
  }

  .relevance-summary {
    display: flex;
    gap: 2rem;
    margin-bottom: 2.5rem;
    padding: 1rem 1.25rem;
    background: var(--color-bg-subtle);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    flex-wrap: wrap;
  }

  .relevance-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: var(--color-text-muted);
  }

  .relevance-item strong {
    color: var(--color-text);
  }

  .rel-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .rel-high { background: var(--importance-high); }
  .rel-medium { background: var(--importance-medium); }

  .tool-section {
    margin-bottom: 3rem;
  }

  .section-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 1.25rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--color-border);
  }

  .section-header h2 {
    font-size: 1.15rem;
    position: relative;
    padding-left: 0.85rem;
  }

  .section-header h2::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.15em;
    height: 0.8em;
    width: 3px;
    background: var(--color-accent);
    border-radius: 2px;
  }

  .tool-count {
    font-size: 0.8rem;
    color: var(--color-text-subtle);
    font-family: var(--font-mono);
  }

  .cta-section {
    text-align: center;
    padding: 3rem 1rem;
    border-top: 1px solid var(--color-border);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    color: var(--color-text-muted);
  }
</style>
