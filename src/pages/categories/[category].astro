---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { CATEGORIES, categoryToSlug, slugToCategory, CATEGORY_DESCRIPTIONS } from '../../utils/categories';
import { getReadingTime } from '../../utils/reading-time';

export async function getStaticPaths() {
  const allPosts = await getCollection('blog');

  return CATEGORIES.map((cat) => {
    const slug = categoryToSlug(cat);
    const posts = allPosts
      .filter((p) => p.data.category === cat)
      .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

    return {
      params: { category: slug },
      props: { categoryName: cat, posts },
    };
  });
}

const base = import.meta.env.BASE_URL;
const { categoryName, posts } = Astro.props;
const description = CATEGORY_DESCRIPTIONS[categoryName] ?? '';
---

<BaseLayout title={categoryName} description={description}>
  <div class="container">
    <div class="page-header">
      <div class="breadcrumb">
        <a href={base}>ホーム</a>
        <span aria-hidden="true">›</span>
        <a href={`${base}blog`}>記事一覧</a>
        <span aria-hidden="true">›</span>
        <span>{categoryName}</span>
      </div>
      <h1>
        <span class="category-badge">{categoryName}</span>
      </h1>
      {description && <p class="page-desc">{description}</p>}
      <p class="post-count">{posts.length} 件の記事</p>
    </div>

    {posts.length > 0 ? (
      <div class="grid-2">
        {posts.map((post) => (
          <ArticleCard
            slug={post.slug}
            title={post.data.title}
            date={post.data.date}
            category={post.data.category}
            tags={post.data.tags}
            tool={post.data.tool}
            importance={post.data.importance}
            summary={post.data.summary}
            readingTime={getReadingTime(post.body)}
          />
        ))}
      </div>
    ) : (
      <div class="empty-state">
        <p>このカテゴリの記事はまだ準備中です。</p>
        <a href={`${base}blog`} class="btn btn-outline">全記事を見る</a>
      </div>
    )}

    <!-- All Categories -->
    <section class="other-categories">
      <h2>他のカテゴリ</h2>
      <div class="category-chips">
        {CATEGORIES.filter((c) => c !== categoryName).map((cat) => (
          <a href={`${base}categories/${categoryToSlug(cat)}`} class="category-chip">
            {cat}
          </a>
        ))}
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .page-header {
    padding: 2.5rem 0 2rem;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 2rem;
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.8rem;
    color: var(--color-text-muted);
    margin-bottom: 1rem;
    flex-wrap: wrap;
  }

  .breadcrumb a {
    color: var(--color-text-muted);
    transition: color 0.15s;
  }

  .breadcrumb a:hover {
    color: var(--color-accent);
  }

  .page-header h1 {
    margin-bottom: 0.75rem;
  }

  .page-header .category-badge {
    font-size: 1rem;
    padding: 0.3em 0.85em;
  }

  .page-desc {
    font-size: 0.95rem;
    color: var(--color-text-muted);
    margin: 0.5rem 0 0.5rem;
    max-width: 600px;
  }

  .post-count {
    font-size: 0.82rem;
    color: var(--color-text-subtle);
    font-family: var(--font-mono);
    margin: 0;
  }

  .empty-state {
    text-align: center;
    padding: 4rem 1rem;
    color: var(--color-text-muted);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
  }

  .other-categories {
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
  }

  .other-categories h2 {
    font-size: 1.1rem;
    margin-bottom: 1rem;
    color: var(--color-text-muted);
  }

  .category-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .category-chip {
    display: inline-block;
    padding: 0.4em 1em;
    background: var(--color-bg-muted);
    border: 1px solid var(--color-border);
    border-radius: 9999px;
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--color-text);
    transition: all 0.15s;
  }

  .category-chip:hover {
    background: var(--color-navy);
    color: #ffffff;
    border-color: var(--color-navy);
  }
</style>
