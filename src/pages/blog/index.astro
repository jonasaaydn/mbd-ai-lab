---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { CATEGORIES, categoryToSlug } from '../../utils/categories';
import { getReadingTime } from '../../utils/reading-time';

const base = import.meta.env.BASE_URL;
const allPosts = await getCollection('blog');
const posts = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const url = Astro.url;
const selectedCategory = url.searchParams.get('category') ?? '';
const filteredPosts = selectedCategory
  ? posts.filter((p) => categoryToSlug(p.data.category) === selectedCategory)
  : posts;
---

<BaseLayout
  title="記事一覧"
  description="MBD・Simulink・CAE・AI ツールに関する技術記事の一覧"
>
  <div class="container">
    <div class="page-header">
      <h1>記事一覧</h1>
      <p class="page-desc">全 {filteredPosts.length} 件の記事</p>
    </div>

    <!-- Category Filter -->
    <div class="filter-bar">
      <a
        href={`${base}blog`}
        class:list={['filter-chip', { active: !selectedCategory }]}
      >
        すべて
      </a>
      {CATEGORIES.map((cat) => (
        <a
          href={`${base}blog?category=${categoryToSlug(cat)}`}
          class:list={['filter-chip', { active: selectedCategory === categoryToSlug(cat) }]}
        >
          {cat}
        </a>
      ))}
    </div>

    {filteredPosts.length > 0 ? (
      <div class="grid-2">
        {filteredPosts.map((post) => (
          <ArticleCard
            slug={post.slug}
            title={post.data.title}
            date={post.data.date}
            category={post.data.category}
            tags={post.data.tags}
            tool={post.data.tool}
            importance={post.data.importance}
            summary={post.data.summary}
            readingTime={getReadingTime(post.body)}
          />
        ))}
      </div>
    ) : (
      <div class="empty-state">
        <p>このカテゴリの記事はまだありません。</p>
        <a href={`${base}blog`} class="btn btn-outline">全記事を見る</a>
      </div>
    )}
  </div>
</BaseLayout>

<style>
  .page-header {
    padding: 2.5rem 0 1.5rem;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 1.5rem;
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
  }

  .page-desc {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin: 0;
  }

  .filter-bar {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 2rem;
  }

  .filter-chip {
    display: inline-block;
    padding: 0.35em 0.9em;
    font-size: 0.82rem;
    font-weight: 500;
    border: 1px solid var(--color-border);
    border-radius: 9999px;
    color: var(--color-text-muted);
    background: var(--color-bg);
    transition: all 0.15s;
    white-space: nowrap;
  }

  .filter-chip:hover {
    border-color: var(--color-navy-mid);
    color: var(--color-navy);
    background: var(--color-bg-subtle);
  }

  .filter-chip.active {
    background: var(--color-navy);
    color: #ffffff;
    border-color: var(--color-navy);
  }

  .empty-state {
    text-align: center;
    padding: 4rem 1rem;
    color: var(--color-text-muted);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
  }
</style>
