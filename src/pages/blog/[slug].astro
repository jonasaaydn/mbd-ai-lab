---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import CategoryIllustration from '../../components/CategoryIllustration.astro';
import { categoryToSlug } from '../../utils/categories';
import { getReadingTime } from '../../utils/reading-time';

const base = import.meta.env.BASE_URL;

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await post.render();

const { title, date, category, tags, tool, official_url, importance, summary } = post.data;

// 目次: h2・h3 のみ
const tocHeadings = headings.filter((h) => h.depth === 2 || h.depth === 3);

const formattedDate = date.toLocaleDateString('ja-JP', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const importanceLabel = { high: '重要', medium: '注目', low: '参考' }[importance];
const readingTime = getReadingTime(post.body);

const allPosts = await getCollection('blog');

// 関連記事: 同カテゴリから最新3件（自分自身を除く）
const related = allPosts
  .filter((p) => p.slug !== post.slug && p.data.category === category)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

// シリーズ検出（スラグのプレフィックスで判定）
const SERIES_PREFIXES: Record<string, string> = {
  'student-formula-': '学生フォーミュラ実践シリーズ',
  'weekly-ai-update-': 'Weekly AI Update',
};
const seriesEntry = Object.entries(SERIES_PREFIXES).find(([prefix]) => post.slug.startsWith(prefix));
const seriesName = seriesEntry?.[1] ?? null;
const seriesPrefix = seriesEntry?.[0] ?? null;
const seriesPosts = seriesPrefix
  ? allPosts
      .filter((p) => p.slug.startsWith(seriesPrefix))
      .sort((a, b) => a.data.date.valueOf() - b.data.date.valueOf())
  : [];
const seriesIndex = seriesPosts.findIndex((p) => p.slug === post.slug);
const prevPost = seriesIndex > 0 ? seriesPosts[seriesIndex - 1] : null;
const nextPost = seriesIndex < seriesPosts.length - 1 ? seriesPosts[seriesIndex + 1] : null;
---

<BaseLayout
  title={title}
  description={summary}
  ogType="article"
  canonicalPath={`/blog/${post.slug}/`}
>
  <article class="article-page">
    <div class="article-header-wrap">
      <div class="container article-header">
        <div class="article-meta-top">
          <a href={`${base}categories/${categoryToSlug(category)}`} class="category-badge">
            {category}
          </a>
          <span class={`badge badge-importance-${importance}`}>
            <span class={`importance-dot importance-dot-${importance}`}></span>
            {importanceLabel}
          </span>
          <span class="reading-time-badge">{readingTime} min read</span>
          {seriesName && (
            <span class="series-badge">
              {seriesName} &mdash; {seriesIndex + 1}/{seriesPosts.length}
            </span>
          )}
        </div>

        <h1 class="article-title">{title}</h1>
        <p class="article-summary">{summary}</p>

        <div class="article-info">
          <div class="info-grid">
            <div class="info-item">
              <span class="info-label">公開日</span>
              <time class="info-value" datetime={date.toISOString()}>{formattedDate}</time>
            </div>
            {tool && (
              <div class="info-item">
                <span class="info-label">対象ツール</span>
                <span class="info-value info-tool">{tool}</span>
              </div>
            )}
            {official_url && (
              <div class="info-item">
                <span class="info-label">公式サイト</span>
                <a
                  href={official_url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="info-value info-link"
                >
                  {new URL(official_url).hostname} ↗
                </a>
              </div>
            )}
          </div>

          <div class="article-tags">
            {tags.map((tag) => <span class="tag">{tag}</span>)}
          </div>
        </div>
      </div>
    </div>

    <!-- カテゴリイラスト -->
    <div class="article-illustration">
      <CategoryIllustration category={category} />
    </div>

    <div class="container article-layout">
      <div class="article-body prose" data-pagefind-body>
        <Content />
      </div>

      <aside class="article-sidebar" data-pagefind-ignore>
        {tocHeadings.length >= 3 && (
          <div class="sidebar-card toc-card">
            <h3 class="sidebar-title">目次</h3>
            <nav class="toc">
              {tocHeadings.map((h) => (
                <a href={`#${h.slug}`} class:list={['toc-link', `toc-h${h.depth}`]}>
                  {h.text}
                </a>
              ))}
            </nav>
          </div>
        )}

        <div class="sidebar-card">
          <h3 class="sidebar-title">記事情報</h3>
          <dl class="sidebar-dl">
            <dt>カテゴリ</dt>
            <dd>
              <a href={`${base}categories/${categoryToSlug(category)}`} class="category-badge">
                {category}
              </a>
            </dd>
            <dt>重要度</dt>
            <dd>
              <span class={`badge badge-importance-${importance}`}>
                {importanceLabel}
              </span>
            </dd>
            <dt>読了時間</dt>
            <dd class="info-value">{readingTime} 分</dd>
            <dt>タグ</dt>
            <dd class="tags-dd">
              {tags.map((tag) => <span class="tag">{tag}</span>)}
            </dd>
            {tool && (
              <>
                <dt>対象ツール</dt>
                <dd class="info-tool">{tool}</dd>
              </>
            )}
            {official_url && (
              <>
                <dt>公式URL</dt>
                <dd>
                  <a href={official_url} target="_blank" rel="noopener noreferrer" class="info-link">
                    公式サイトを開く ↗
                  </a>
                </dd>
              </>
            )}
          </dl>
        </div>

        <a href={`${base}blog`} class="btn btn-outline back-btn">← 記事一覧に戻る</a>
      </aside>
    </div>

    <!-- シリーズナビゲーション -->
    {seriesName && (prevPost || nextPost) && (
      <div class="container series-nav">
        <div class="series-nav-header">
          <span class="series-nav-label">{seriesName}</span>
        </div>
        <div class="series-nav-grid">
          <div class="series-nav-item">
            {prevPost && (
              <a href={`${base}blog/${prevPost.slug}`} class="series-nav-link prev">
                <span class="series-nav-dir">← 前の記事</span>
                <span class="series-nav-title">{prevPost.data.title}</span>
              </a>
            )}
          </div>
          <div class="series-nav-item">
            {nextPost && (
              <a href={`${base}blog/${nextPost.slug}`} class="series-nav-link next">
                <span class="series-nav-dir">次の記事 →</span>
                <span class="series-nav-title">{nextPost.data.title}</span>
              </a>
            )}
          </div>
        </div>
      </div>
    )}

    <!-- 関連記事 -->
    {related.length > 0 && (
      <div class="container related-section">
        <div class="section-header">
          <h2>同じカテゴリの記事</h2>
          <a href={`${base}categories/${categoryToSlug(category)}`} class="section-link">
            {category} をすべて見る →
          </a>
        </div>
        <div class="grid-3">
          {related.map((p) => (
            <ArticleCard
              slug={p.slug}
              title={p.data.title}
              date={p.data.date}
              category={p.data.category}
              tags={p.data.tags}
              tool={p.data.tool}
              importance={p.data.importance}
              summary={p.data.summary}
              readingTime={getReadingTime(p.body)}
            />
          ))}
        </div>
      </div>
    )}
  </article>
</BaseLayout>

<style>
  .article-header-wrap {
    background: var(--color-navy);
    color: #ffffff;
    padding: 3rem 0 2.5rem;
  }

  .article-header {
    max-width: var(--container-max);
  }

  .article-meta-top {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1rem;
    flex-wrap: wrap;
  }

  .article-header .category-badge {
    background: rgba(255, 255, 255, 0.15);
    color: #e2e8f0;
    border: 1px solid rgba(255, 255, 255, 0.2);
  }

  .reading-time-badge {
    font-size: 0.68rem;
    font-weight: 600;
    font-family: var(--font-mono);
    color: rgba(255, 255, 255, 0.45);
    letter-spacing: 0.04em;
  }

  .article-title {
    font-size: clamp(1.4rem, 3.5vw, 2rem);
    font-weight: 800;
    color: #ffffff;
    letter-spacing: -0.03em;
    line-height: 1.3;
    margin-bottom: 0.85rem;
  }

  .article-summary {
    font-size: 1rem;
    color: #94a3b8;
    line-height: 1.7;
    margin-bottom: 1.5rem;
    max-width: 660px;
  }

  .article-info {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }

  .info-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem 2rem;
  }

  .info-item {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .info-label {
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #475569;
  }

  .info-value {
    font-size: 0.875rem;
    color: #cbd5e1;
    font-family: var(--font-mono);
  }

  .info-tool {
    font-weight: 600;
    color: #86efac;
    font-family: var(--font-sans);
  }

  .info-link {
    color: #7dd3fc;
    transition: color 0.15s;
  }

  .info-link:hover {
    color: #38bdf8;
    text-decoration: underline;
  }

  .article-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }

  .article-header .tag {
    background: rgba(255, 255, 255, 0.1);
    color: #cbd5e1;
    border-color: rgba(255, 255, 255, 0.15);
  }

  /* Illustration */
  .article-illustration {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0 1.25rem;
  }

  .article-illustration svg {
    width: 100%;
    height: auto;
    border-radius: 0 0 var(--radius-lg) var(--radius-lg);
    display: block;
  }

  /* Layout */
  .article-layout {
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: 3rem;
    padding-top: 3rem;
    padding-bottom: 4rem;
    align-items: start;
  }

  /* Prose */
  .prose {
    min-width: 0;
  }

  .prose :global(h2) {
    font-size: 1.35rem;
    font-weight: 700;
    color: var(--color-navy);
    margin: 2.5rem 0 1rem;
    padding-top: 0.5rem;
    border-top: 2px solid var(--color-border);
    position: relative;
    padding-left: 0.85rem;
  }

  .prose :global(h2)::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.5rem;
    height: 0.8em;
    width: 3px;
    background: var(--color-accent);
    border-radius: 2px;
  }

  .prose :global(h3) {
    font-size: 1.1rem;
    color: var(--color-navy);
    margin: 2rem 0 0.75rem;
  }

  .prose :global(p) {
    line-height: 1.85;
    color: var(--color-text);
    margin-bottom: 1.25rem;
  }

  .prose :global(ul),
  .prose :global(ol) {
    margin: 0.75rem 0 1.25rem;
  }

  .prose :global(li) {
    line-height: 1.75;
    margin-bottom: 0.4rem;
  }

  .prose :global(strong) {
    font-weight: 700;
    color: var(--color-navy);
  }

  .prose :global(a) {
    color: var(--color-accent);
    text-decoration: underline;
    text-decoration-color: transparent;
    transition: text-decoration-color 0.15s;
  }

  .prose :global(a):hover {
    text-decoration-color: currentColor;
  }

  /* Shiki コードブロック */
  .prose :global(pre) {
    border-radius: var(--radius-md);
    margin-bottom: 1.5rem;
    overflow-x: auto;
    font-size: 0.875rem;
    line-height: 1.6;
  }

  .prose :global(pre code) {
    background: none;
    border: none;
    padding: 0;
    font-size: inherit;
  }

  /* Sidebar */
  .article-sidebar {
    position: sticky;
    top: 80px;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .sidebar-card {
    background: var(--color-bg-subtle);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 1.25rem;
  }

  .sidebar-title {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
    margin-bottom: 1rem;
  }

  .sidebar-dl {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .sidebar-dl dt {
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-subtle);
    margin-bottom: 0.2rem;
  }

  .sidebar-dl dd {
    font-size: 0.85rem;
    color: var(--color-text);
    margin: 0;
  }

  .tags-dd {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
  }

  .sidebar-dl .info-tool {
    font-weight: 600;
    color: var(--importance-low);
    font-family: var(--font-sans);
    font-size: 0.875rem;
  }

  .sidebar-dl .info-link {
    color: var(--color-accent);
    font-size: 0.85rem;
  }

  .sidebar-dl .info-value {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }

  .back-btn {
    width: 100%;
    justify-content: center;
    font-size: 0.85rem;
  }

  /* シリーズバッジ */
  .series-badge {
    font-size: 0.68rem;
    font-weight: 700;
    color: rgba(255, 255, 255, 0.75);
    background: rgba(220, 38, 38, 0.35);
    border: 1px solid rgba(220, 38, 38, 0.5);
    border-radius: 4px;
    padding: 0.2em 0.65em;
    letter-spacing: 0.03em;
  }

  /* 目次 (TOC) */
  .toc-card {
    order: -1;
  }

  .toc {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }

  .toc-link {
    display: block;
    font-size: 0.8rem;
    color: var(--color-text-muted);
    padding: 0.3em 0.5em;
    border-radius: var(--radius-sm);
    line-height: 1.4;
    transition: color 0.12s, background 0.12s;
    text-decoration: none;
  }

  .toc-link:hover {
    color: var(--color-accent);
    background: var(--color-bg-muted);
  }

  .toc-h3 {
    padding-left: 1.25rem;
    font-size: 0.75rem;
  }

  /* シリーズナビゲーション */
  .series-nav {
    padding: 2.5rem 0;
    border-top: 1px solid var(--color-border);
  }

  .series-nav-header {
    margin-bottom: 1rem;
  }

  .series-nav-label {
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-accent);
  }

  .series-nav-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .series-nav-link {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    padding: 1rem 1.25rem;
    background: var(--color-bg-subtle);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    text-decoration: none;
    transition: border-color 0.15s, background 0.15s;
  }

  .series-nav-link:hover {
    border-color: var(--color-accent);
    background: #fef2f2;
  }

  .series-nav-link.next {
    text-align: right;
  }

  .series-nav-dir {
    font-size: 0.72rem;
    font-weight: 700;
    color: var(--color-accent);
    letter-spacing: 0.04em;
  }

  .series-nav-title {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-navy);
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  @media (max-width: 640px) {
    .series-nav-grid {
      grid-template-columns: 1fr;
    }
    .series-nav-link.next {
      text-align: left;
    }
  }

  /* 関連記事 */
  .related-section {
    padding-bottom: 4rem;
    border-top: 1px solid var(--color-border);
    padding-top: 3rem;
  }

  @media (max-width: 900px) {
    .article-layout {
      grid-template-columns: 1fr;
    }

    .article-sidebar {
      position: static;
      order: -1;
    }
  }
</style>
