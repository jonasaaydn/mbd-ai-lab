---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { categoryToSlug } from '../../utils/categories';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

const { title, date, category, tags, tool, official_url, importance, summary } = post.data;

const formattedDate = date.toLocaleDateString('ja-JP', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const importanceLabel = { high: '重要', medium: '注目', low: '参考' }[importance];
---

<BaseLayout title={title} description={summary}>
  <article class="article-page">
    <div class="article-header-wrap">
      <div class="container article-header">
        <div class="article-meta-top">
          <a href={`/categories/${categoryToSlug(category)}`} class="category-badge">
            {category}
          </a>
          <span class={`badge badge-importance-${importance}`}>
            <span class={`importance-dot importance-dot-${importance}`}></span>
            {importanceLabel}
          </span>
        </div>

        <h1 class="article-title">{title}</h1>
        <p class="article-summary">{summary}</p>

        <div class="article-info">
          <div class="info-grid">
            <div class="info-item">
              <span class="info-label">公開日</span>
              <time class="info-value" datetime={date.toISOString()}>{formattedDate}</time>
            </div>
            {tool && (
              <div class="info-item">
                <span class="info-label">対象ツール</span>
                <span class="info-value info-tool">{tool}</span>
              </div>
            )}
            {official_url && (
              <div class="info-item">
                <span class="info-label">公式サイト</span>
                <a
                  href={official_url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="info-value info-link"
                >
                  {new URL(official_url).hostname} ↗
                </a>
              </div>
            )}
          </div>

          <div class="article-tags">
            {tags.map((tag) => <span class="tag">{tag}</span>)}
          </div>
        </div>
      </div>
    </div>

    <div class="container article-layout">
      <div class="article-body prose">
        <Content />
      </div>

      <aside class="article-sidebar">
        <div class="sidebar-card">
          <h3 class="sidebar-title">記事情報</h3>
          <dl class="sidebar-dl">
            <dt>カテゴリ</dt>
            <dd>
              <a href={`/categories/${categoryToSlug(category)}`} class="category-badge">
                {category}
              </a>
            </dd>
            <dt>重要度</dt>
            <dd>
              <span class={`badge badge-importance-${importance}`}>
                {importanceLabel}
              </span>
            </dd>
            <dt>タグ</dt>
            <dd class="tags-dd">
              {tags.map((tag) => <span class="tag">{tag}</span>)}
            </dd>
            {tool && (
              <>
                <dt>対象ツール</dt>
                <dd class="info-tool">{tool}</dd>
              </>
            )}
            {official_url && (
              <>
                <dt>公式URL</dt>
                <dd>
                  <a href={official_url} target="_blank" rel="noopener noreferrer" class="info-link">
                    公式サイトを開く ↗
                  </a>
                </dd>
              </>
            )}
          </dl>
        </div>

        <a href="/blog" class="btn btn-outline back-btn">← 記事一覧に戻る</a>
      </aside>
    </div>
  </article>
</BaseLayout>

<style>
  .article-header-wrap {
    background: var(--color-navy);
    color: #ffffff;
    padding: 3rem 0 2.5rem;
  }

  .article-header {
    max-width: var(--container-max);
  }

  .article-meta-top {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1rem;
    flex-wrap: wrap;
  }

  .article-header .category-badge {
    background: rgba(255, 255, 255, 0.15);
    color: #e2e8f0;
    border: 1px solid rgba(255, 255, 255, 0.2);
  }

  .article-title {
    font-size: clamp(1.4rem, 3.5vw, 2rem);
    font-weight: 800;
    color: #ffffff;
    letter-spacing: -0.03em;
    line-height: 1.3;
    margin-bottom: 0.85rem;
  }

  .article-summary {
    font-size: 1rem;
    color: #94a3b8;
    line-height: 1.7;
    margin-bottom: 1.5rem;
    max-width: 660px;
  }

  .article-info {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }

  .info-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem 2rem;
  }

  .info-item {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .info-label {
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #475569;
  }

  .info-value {
    font-size: 0.875rem;
    color: #cbd5e1;
    font-family: var(--font-mono);
  }

  .info-tool {
    font-weight: 600;
    color: #86efac;
    font-family: var(--font-sans);
  }

  .info-link {
    color: #7dd3fc;
    transition: color 0.15s;
  }

  .info-link:hover {
    color: #38bdf8;
    text-decoration: underline;
  }

  .article-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }

  .article-header .tag {
    background: rgba(255, 255, 255, 0.1);
    color: #cbd5e1;
    border-color: rgba(255, 255, 255, 0.15);
  }

  /* Layout */
  .article-layout {
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: 3rem;
    padding-top: 3rem;
    padding-bottom: 4rem;
    align-items: start;
  }

  /* Prose */
  .prose {
    min-width: 0;
  }

  .prose :global(h2) {
    font-size: 1.35rem;
    font-weight: 700;
    color: var(--color-navy);
    margin: 2.5rem 0 1rem;
    padding-top: 0.5rem;
    border-top: 2px solid var(--color-border);
    position: relative;
    padding-left: 0.85rem;
  }

  .prose :global(h2)::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.5rem;
    height: 0.8em;
    width: 3px;
    background: var(--color-accent);
    border-radius: 2px;
  }

  .prose :global(h3) {
    font-size: 1.1rem;
    color: var(--color-navy);
    margin: 2rem 0 0.75rem;
  }

  .prose :global(p) {
    line-height: 1.85;
    color: var(--color-text);
    margin-bottom: 1.25rem;
  }

  .prose :global(ul),
  .prose :global(ol) {
    margin: 0.75rem 0 1.25rem;
  }

  .prose :global(li) {
    line-height: 1.75;
    margin-bottom: 0.4rem;
  }

  .prose :global(strong) {
    font-weight: 700;
    color: var(--color-navy);
  }

  .prose :global(a) {
    color: var(--color-accent);
    text-decoration: underline;
    text-decoration-color: transparent;
    transition: text-decoration-color 0.15s;
  }

  .prose :global(a):hover {
    text-decoration-color: currentColor;
  }

  /* Sidebar */
  .article-sidebar {
    position: sticky;
    top: 80px;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .sidebar-card {
    background: var(--color-bg-subtle);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 1.25rem;
  }

  .sidebar-title {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
    margin-bottom: 1rem;
  }

  .sidebar-dl {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .sidebar-dl dt {
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-subtle);
    margin-bottom: 0.2rem;
  }

  .sidebar-dl dd {
    font-size: 0.85rem;
    color: var(--color-text);
    margin: 0;
  }

  .tags-dd {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
  }

  .sidebar-dl .info-tool {
    font-weight: 600;
    color: var(--importance-low);
    font-family: var(--font-sans);
    font-size: 0.875rem;
  }

  .sidebar-dl .info-link {
    color: var(--color-accent);
    font-size: 0.85rem;
  }

  .back-btn {
    width: 100%;
    justify-content: center;
    font-size: 0.85rem;
  }

  @media (max-width: 900px) {
    .article-layout {
      grid-template-columns: 1fr;
    }

    .article-sidebar {
      position: static;
      order: -1;
    }
  }
</style>
