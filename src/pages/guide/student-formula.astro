---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { STUDENT_THEMES, classifyStudentArticle, ALL_THEMES_WITH_FALLBACK } from '../../utils/student-themes';

const base = import.meta.env.BASE_URL;

const allPosts = await getCollection('blog');
const studentPosts = allPosts
  .filter((p) => p.slug.startsWith('student-formula-'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

// 各記事をテーマに分類
const grouped: Record<string, typeof studentPosts> = {};
for (const post of studentPosts) {
  const hay = `${post.data.title} ${post.slug} ${(post.data.tags ?? []).join(' ')}`;
  const theme = classifyStudentArticle(hay);
  (grouped[theme.key] ??= []).push(post);
}

// 表示順：定義順のテーマ → その他。記事0件のテーマは出さない。
const sections = ALL_THEMES_WITH_FALLBACK
  .map((theme) => ({ theme, posts: grouped[theme.key] ?? [] }))
  .filter((s) => s.posts.length > 0);

const description = `学生フォーミュラ向けAI活用記事 ${studentPosts.length}本を、空力CFD・構造FEM・制御MBD・走行データ解析など開発テーマ別に整理した目的別ガイド。`;
---

<BaseLayout
  title="学生フォーミュラ AI活用 目的別ガイド"
  description={description}
  canonicalPath="/guide/student-formula/"
>
  <section class="guide-hero">
    <div class="container">
      <div class="guide-label">STUDENT FORMULA × AI — 目的別ガイド</div>
      <h1 class="guide-title">あなたの担当領域から、AI活用例を探す</h1>
      <p class="guide-desc">
        学生フォーミュラ向けの実践記事 <strong>{studentPosts.length}本</strong> を、
        車両開発のテーマ別に整理しました。空力・構造・制御・データ解析…
        あなたのチームでの担当から、今すぐ使えるAI活用例を見つけてください。
      </p>
      <nav class="theme-jump">
        {sections.map(({ theme, posts }) => (
          <a href={`#${theme.key}`} class="theme-jump-chip">
            {theme.label} <span class="jump-count">{posts.length}</span>
          </a>
        ))}
      </nav>
    </div>
  </section>

  <div class="container guide-body">
    {sections.map(({ theme, posts }) => (
      <section class="theme-section" id={theme.key}>
        <div class="theme-head">
          <div class="theme-head-main">
            <h2 class="theme-name">{theme.label}</h2>
            {theme.phase && <span class="theme-phase">{theme.phase}</span>}
          </div>
          <span class="theme-count">{posts.length}本</span>
        </div>
        <p class="theme-desc">{theme.description}</p>

        <ul class="article-rows">
          {posts.map((post) => (
            <li class="article-row">
              <a href={`${base}blog/${post.slug}`} class="row-link">
                <span class="row-title">{post.data.title.replace(/^【学生フォーミュラ実践】/, '')}</span>
                {post.data.tool && <span class="row-tool">{post.data.tool}</span>}
              </a>
            </li>
          ))}
        </ul>
      </section>
    ))}

    <div class="guide-foot">
      <p>探している内容が見つからない場合は、キーワード検索もご利用ください。</p>
      <div class="guide-foot-actions">
        <a href={`${base}search`} class="btn btn-primary">記事を検索する</a>
        <a href={`${base}blog`} class="btn btn-outline">全記事を見る</a>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .guide-hero {
    background: var(--color-navy);
    color: #fff;
    padding: 3rem 0 2.5rem;
  }
  .guide-label {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    color: var(--color-accent);
    font-family: var(--font-mono);
    margin-bottom: 0.75rem;
  }
  .guide-title {
    font-size: clamp(1.5rem, 4vw, 2.2rem);
    font-weight: 800;
    color: #fff;
    letter-spacing: -0.03em;
    margin-bottom: 0.85rem;
  }
  .guide-desc {
    font-size: 1rem;
    color: #94a3b8;
    line-height: 1.8;
    max-width: 640px;
    margin-bottom: 1.5rem;
  }
  .guide-desc strong { color: #fca5a5; }

  .theme-jump {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .theme-jump-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.8rem;
    font-weight: 600;
    color: #e2e8f0;
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.16);
    border-radius: 9999px;
    padding: 0.4em 0.85em;
    transition: background 0.15s, border-color 0.15s;
  }
  .theme-jump-chip:hover {
    background: rgba(220,38,38,0.25);
    border-color: rgba(220,38,38,0.5);
    color: #fff;
  }
  .jump-count {
    font-size: 0.7rem;
    font-family: var(--font-mono);
    color: #94a3b8;
  }

  .guide-body { padding: 2.5rem 1.25rem 4rem; }

  .theme-section {
    margin-bottom: 2.75rem;
    scroll-margin-top: 80px;
  }
  .theme-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    border-bottom: 2px solid var(--color-border);
    padding-bottom: 0.6rem;
  }
  .theme-head-main {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    flex-wrap: wrap;
  }
  .theme-name {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-navy);
    position: relative;
    padding-left: 0.85rem;
  }
  .theme-name::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.15em;
    height: 0.8em;
    width: 3px;
    background: var(--color-accent);
    border-radius: 2px;
  }
  .theme-phase {
    font-size: 0.72rem;
    font-weight: 600;
    color: var(--color-text-muted);
    background: var(--color-bg-subtle);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    padding: 0.2em 0.6em;
  }
  .theme-count {
    font-size: 0.8rem;
    color: var(--color-text-subtle);
    font-family: var(--font-mono);
    flex-shrink: 0;
  }
  .theme-desc {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    line-height: 1.7;
    margin: 0.85rem 0 1rem;
  }

  .article-rows {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.4rem 1.5rem;
  }
  .article-row { margin: 0; }
  .row-link {
    display: flex;
    align-items: baseline;
    gap: 0.6rem;
    padding: 0.5rem 0.4rem;
    border-radius: var(--radius-sm);
    text-decoration: none;
    transition: background 0.12s;
  }
  .row-link:hover { background: var(--color-bg-subtle); }
  .row-link::before {
    content: '›';
    color: var(--color-accent);
    font-weight: 700;
    flex-shrink: 0;
  }
  .row-title {
    font-size: 0.875rem;
    color: var(--color-text);
    line-height: 1.5;
    font-weight: 500;
  }
  .row-link:hover .row-title { color: var(--color-accent); }
  .row-tool {
    font-size: 0.68rem;
    font-weight: 600;
    color: #15803d;
    background: #f0fdf4;
    border: 1px solid #bbf7d0;
    border-radius: var(--radius-sm);
    padding: 0.1em 0.5em;
    white-space: nowrap;
    flex-shrink: 0;
    margin-left: auto;
  }

  .guide-foot {
    margin-top: 1rem;
    padding: 2rem;
    background: var(--color-bg-subtle);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    text-align: center;
    color: var(--color-text-muted);
  }
  .guide-foot-actions {
    display: flex;
    gap: 0.75rem;
    justify-content: center;
    margin-top: 1rem;
    flex-wrap: wrap;
  }

  @media (max-width: 680px) {
    .article-rows { grid-template-columns: 1fr; }
  }
</style>
